<?xml version="1.0" encoding="utf-8"?>
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
    IgnorableNamespaces="uap rescap desktop">

  <!-- Identity Name / Application Id / StartupTask id MUST stay "PulseBar":
       this is the Store-reserved package identity in Partner Center (the
       publisher-hash family name is derived from it). Renaming it makes the
       Store treat this as a different app and breaks updates. The user-visible
       name is DisplayName / DefaultTile below (PulseDeck). -->
  <Identity Name="PapanikolaouFokion.PulseBar"
            Publisher="CN=4DDDFD1C-63EA-4604-9FCA-35D0F04C71E3"
            Version="2.9.5.0"
            ProcessorArchitecture="x64" />

  <!-- NOTE: registry write virtualization stays ENABLED. Disabling it needs
       the unvirtualizedResources restricted capability, which the Store
       denied (policy 10.6.3, review of 2026-07-10). Consequently the classic
       context-menu toggle cannot work from inside the MSIX container, so the
       app hides that tool when running packaged (see _is_msix filter in
       taskbar_widget.py). The portable/installer builds keep the feature. -->
  <Properties>
    <DisplayName>PulseDeck</DisplayName>
    <PublisherDisplayName>Papanikolaou Fokion</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.26200.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

  <Applications>
    <Application Id="PulseBar" Executable="PulseDeck.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
          DisplayName="PulseDeck"
          Description="Your PC's pulse, right on the taskbar — live CPU, RAM, GPU, network, disk, battery and power."
          BackgroundColor="#0d1117"
          Square150x150Logo="Assets\Square150x150Logo.png"
          Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile
            Wide310x150Logo="Assets\Wide310x150Logo.png"
            Square71x71Logo="Assets\Square71x71Logo.png"
            Square310x310Logo="Assets\Square310x310Logo.png" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" BackgroundColor="#0d1117" />
      </uap:VisualElements>
      <Extensions>
        <desktop:Extension Category="windows.startupTask"
                           Executable="PulseDeck.exe"
                           EntryPoint="Windows.FullTrustApplication">
          <desktop:StartupTask TaskId="PulseBarStartup" Enabled="true" DisplayName="PulseDeck" />
        </desktop:Extension>
      </Extensions>
    </Application>
  </Applications>
</Package>
